    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE compromissos \nSET \n  titulo = COALESCE(NULLIF($1, ''), titulo),\n  data = COALESCE(NULLIF($2, '')::date, data),\n  hora = COALESCE(NULLIF($3, '')::time, hora),\n  categoria = COALESCE(NULLIF($4, ''), categoria)\nWHERE id = $5\nAND remetente = $6\nRETURNING titulo, TO_CHAR(data, 'DD/MM/YYYY') as data, TO_CHAR(hora, 'HH24:MI') as hora;",
        "options": {
          "queryReplacement": "={{ $json.output.titulo }}, {{ $json.output.data }}, {{ $json.output.hora }}, {{ $json.output.categoria }}, {{ $json.output.id_compromisso }}, {{ $('Webhook').item.json.body.data.key.remoteJid }}"
