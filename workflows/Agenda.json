    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nif (items.length === 0) {\n  return [{ json: { mensagem: \"Você não tem compromissos pendentes! 🎉\" } }];\n}\n\nlet texto = \"📋 Seus compromissos pendentes:\\n\\n\";\n\nfor (const item of items) {\n  const c = item.json;\n  texto += `${c.id}. ${c.titulo}\\n📅 ${c.data} ${c.hora ? 'às ' + c.hora : ''}\\n🏷️ ${c.categoria}\\n\\n`;\n}\n\nreturn [{ json: { mensagem: texto } }];"
      },
