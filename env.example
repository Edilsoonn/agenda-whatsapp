# === Evolution API ===
AUTHENTICATION_API_KEY=troque-por-uma-chave-secreta-forte

# === PostgreSQL (compartilhado entre Evolution API e o banco da Agenda) ===
POSTGRES_USER=evolution
POSTGRES_PASSWORD=troque-por-senha-forte
POSTGRES_DB=evolution

# === Google Gemini API ===
# Obtenha gratuitamente em https://aistudio.google.com
GEMINI_API_KEY=sua-chave-do-google-ai-studio

# === WhatsApp ===
# Número/grupo autorizado a interagir com o bot (formato: numero@s.whatsapp.net ou id@g.us)
WHATSAPP_ALLOWED_JID=00000000000@g.us
